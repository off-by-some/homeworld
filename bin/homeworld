#!/bin/sh
# homeworld — personal provisioning runtime
# https://github.com/cassidybridges/linux-toolkit
set -u

# Locate the lib directory relative to this script regardless of how it was
# invoked. cd -P resolves symlinks so $0 inside ~/.local/bin points back to
# the real tree.
_hw_dir=$(cd -P "$(dirname "$0")/.." 2>/dev/null && pwd) || exit 1
_hw_lib="$_hw_dir/lib/homeworld"

if [ ! -d "$_hw_lib" ]; then
    printf 'homeworld: cannot find lib directory at %s\n' "$_hw_lib" >&2
    printf 'homeworld: the installation may be corrupt — rerun the bootstrap installer\n' >&2
    exit 1
fi

# Export our own location so install.sh scripts can invoke 'homeworld' even
# when ~/.local/bin isn't yet on the user's PATH. We prepend our directory
# to PATH before running each module's install.sh.
HW_SELF_BIN="$_hw_dir/bin"
export HW_SELF_BIN

. "$_hw_lib/core.sh"
. "$_hw_lib/platform.sh"
. "$_hw_lib/module.sh"
. "$_hw_lib/transaction.sh"
. "$_hw_lib/state.sh"
. "$_hw_lib/repo.sh"
. "$_hw_lib/config.sh"
. "$_hw_lib/generation.sh"
. "$_hw_lib/install.sh"

# ---------------------------------------------------------------------------
# usage
# ---------------------------------------------------------------------------

usage() {
    cat >&2 <<'EOF'
Usage:
  homeworld <command> [arguments]

Common commands:
  homeworld init <path|url>                         remember a setup source
  homeworld install [module] [--dry-run] [--yes]    build and activate a generation
  homeworld list                                    show modules and skip reasons
  homeworld status                                  show active generation paths
  homeworld doctor                                  check local setup health
  homeworld update [--dependencies] [--install]     refresh source and optionally install

Resource lifecycle:
  add   snapshot or register a named resource in the pending generation
  link  expose an already-named resource at a managed destination
  path  print the generation-aware path for a named resource

Resources:
  homeworld repo add <source> <namespace> [--ref <ref>]
  homeworld repo link <namespace> <destination>
  homeworld repo path <namespace>
  homeworld repo update <namespace|--all>

  homeworld config add <source> <name>
  homeworld config link <name> <destination>
  homeworld config path <module/name>

  homeworld asset add <source> <name>
  homeworld asset link <name> <destination>
  homeworld asset path <module/name>

  homeworld command add <source> <name>
  homeworld command path <name|self>

  homeworld state bind <name> <path>
  homeworld state link <name-or-path> <destination>

Generations:
  homeworld generation path [self]
  homeworld generation list
  homeworld generation rollback
  homeworld generation gc

Install-hook context:
  homeworld module path
EOF
}

# ---------------------------------------------------------------------------
# Helpers used only by the CLI layer
# ---------------------------------------------------------------------------

# _hw_read_source — read the configured source path, die if not set.
_hw_read_source() {
    if [ ! -f "$HW_STATE/source" ]; then
        hw_die "no source configured" \
               "Run 'homeworld init <path>' to point homeworld at a module directory."
    fi
    cat "$HW_STATE/source"
}

# _hw_ensure_dirs — create runtime dirs on first use.
_hw_ensure_dirs() {
    mkdir -p \
        "$HW_DATA/generations" \
        "$(hw_mirrors_dir)" \
        "$(hw_checkouts_dir)" \
        "$(hw_orphaned_dir)" \
        "$(hw_state_bindings_dir)" \
        "$(hw_state_targets_dir)" \
        "$HW_STATE/locks" \
        "$HW_STATE/logs" \
        "$HW_CACHE"
}

# _hw_write_env_sh — generate ~/.config/homeworld/env.sh.
# Shell modules source this once to put homeworld-managed commands on PATH.
_hw_write_env_sh() {
    _hwes_dir="${XDG_CONFIG_HOME:-$HOME/.config}/homeworld"
    mkdir -p "$_hwes_dir"
    # Single-quoted heredoc avoids expansion in the written file — the variables
    # should expand when the user's shell sources it, not when we write it.
    printf '%s\n' \
        '# Generated by homeworld — do not edit' \
        '_hw_bin="${XDG_DATA_HOME:-$HOME/.local/share}/homeworld/current/bin"' \
        'case ":$PATH:" in' \
        '    *":$_hw_bin:"*) ;;' \
        '    *) export PATH="$_hw_bin:$PATH" ;;' \
        'esac' \
        'unset _hw_bin' \
        > "$_hwes_dir/env.sh"
}

# _hw_collect_all_packages moddir names provider — collect all packages for
# the install plan into a temp file and return the path.
_hw_collect_all_packages() {
    _hwcap_moddir="$1"
    _hwcap_names="$2"
    _hwcap_provider="$3"

    _hwcap_tmp=$(mktemp)
    for _hwcap_name in $_hwcap_names; do
        hw_module_collect_packages "$_hwcap_moddir" "$_hwcap_name" "$_hwcap_provider" >> "$_hwcap_tmp"
    done
    printf '%s' "$_hwcap_tmp"
}

# _hw_resolve_deps moddir name all_names — return name plus all transitive deps,
# filtered to modules that exist in all_names (the applicable set).
_hw_resolve_deps() {
    _hwrd_moddir="$1"
    _hwrd_name="$2"
    _hwrd_all="$3"  # space-separated applicable module names

    # BFS-style expansion into a result set
    _hwrd_queue="$_hwrd_name"
    _hwrd_result=""

    while [ -n "$_hwrd_queue" ]; do
        _hwrd_next_queue=""
        for _hwrd_n in $_hwrd_queue; do
            # Skip if already in result
            _hwrd_already=0
            for _hwrd_r in $_hwrd_result; do
                [ "$_hwrd_r" = "$_hwrd_n" ] && { _hwrd_already=1; break; }
            done
            [ "$_hwrd_already" = "1" ] && continue

            # Check it's in the applicable set
            _hwrd_in_all=0
            for _hwrd_a in $_hwrd_all; do
                [ "$_hwrd_a" = "$_hwrd_n" ] && { _hwrd_in_all=1; break; }
            done
            if [ "$_hwrd_in_all" = "0" ]; then
                hw_die "module '$_hwrd_name' depends on '$_hwrd_n' which is not applicable on this platform"
            fi

            _hwrd_result="$_hwrd_result $_hwrd_n"

            # Queue its dependencies
            _hwrd_deps=$(hw_module_get "$_hwrd_moddir" "$_hwrd_n" "depends")
            for _hwrd_dep in $_hwrd_deps; do
                _hwrd_next_queue="$_hwrd_next_queue $_hwrd_dep"
            done
        done
        _hwrd_queue="$_hwrd_next_queue"
    done

    printf '%s' "${_hwrd_result# }"
}


# _hw_module_plan_record moddir name platform distro provider root_name
# Print: STATUS<TAB>DETAIL<TAB>APPLICABLE<TAB>DEFAULT_INSTALL
# APPLICABLE means a targeted install may request the module. DEFAULT_INSTALL
# additionally accounts for HOMEWORLD_AUTO_INSTALL.
_hw_module_plan_record() {
    _hwmpr_moddir="$1"
    _hwmpr_name="$2"
    _hwmpr_platform="$3"
    _hwmpr_distro="$4"
    _hwmpr_provider="$5"
    _hwmpr_root_name="$6"

    _hwmpr_reason=$(hw_module_applicable "$_hwmpr_moddir" "$_hwmpr_name" "$_hwmpr_platform" "$_hwmpr_distro")
    _hwmpr_ok=$?
    if [ "$_hwmpr_ok" != "0" ]; then
        printf 'SKIP\t%s\t0\t0\n' "$_hwmpr_reason"
        return 0
    fi

    _hwmpr_path=$(hw_module_get "$_hwmpr_moddir" "$_hwmpr_name" "path")
    if [ -d "$_hwmpr_path/packages" ] && [ -n "$_hwmpr_provider" ]; then
        if [ ! -f "$_hwmpr_path/packages/${_hwmpr_provider}.txt" ]; then
            printf 'SKIP\tno package file for %s\t0\t0\n' "$_hwmpr_provider"
            return 0
        fi
    elif [ -d "$_hwmpr_path/packages" ] && [ -z "$_hwmpr_provider" ]; then
        printf 'SKIP\tno package provider for this distro\t0\t0\n'
        return 0
    fi

    _hwmpr_auto=$(hw_module_get "$_hwmpr_moddir" "$_hwmpr_name" "auto_install")
    if [ "$_hwmpr_name" = "$_hwmpr_root_name" ] || [ "${_hwmpr_auto:-true}" != "false" ]; then
        _hwmpr_desc=$(hw_module_get "$_hwmpr_moddir" "$_hwmpr_name" "description")
        printf 'INSTALL\t%s\t1\t1\n' "$_hwmpr_desc"
    else
        printf 'SKIP\tauto_install=false\t1\t0\n'
    fi
}

# _hw_print_module_header width
_hw_print_module_header() {
    _hwpmh_width="$1"
    printf '  %s%-7s%s  %-*s  %s\n' \
        "$_HW_C_BOLD" "STATUS" "$_HW_C_RST" "$_hwpmh_width" "MODULE" "DETAILS"
    printf '  %-7s  %-*s  %s\n' \
        "-------" "$_hwpmh_width" "------" "-------"
}

# _hw_print_module_row status display_name detail width
_hw_print_module_row() {
    _hwpmr_status="$1"
    _hwpmr_display="$2"
    _hwpmr_detail="$3"
    _hwpmr_width="$4"

    case "$_hwpmr_status" in
        INSTALL) _hwpmr_color=$_HW_C_OK ;;
        SKIP)    _hwpmr_color=$_HW_C_WARN ;;
        *)       _hwpmr_color=$_HW_C_BOLD ;;
    esac

    printf '  %s%-7s%s  %-*s  %s\n' \
        "$_hwpmr_color" "$_hwpmr_status" "$_HW_C_RST" \
        "$_hwpmr_width" "$_hwpmr_display" "$_hwpmr_detail"
}

# ---------------------------------------------------------------------------
# cmd_init
# ---------------------------------------------------------------------------

cmd_init() {
    [ $# -gt 0 ] || hw_die "usage: homeworld init <path|url>"

    _ci_arg="$1"
    _hw_ensure_dirs

    # Distinguish local paths from URLs. A URL must start with a scheme or
    # git@ — anything that looks like a filesystem path is local.
    case "$_ci_arg" in
        http://* | https://* | git@* | ssh://*)
            # Managed source: clone into cache
            hw_require git
            _ci_clone_dest="$HW_CACHE/repo"

            if [ -d "$_ci_clone_dest/.git" ]; then
                hw_log "managed clone already exists at $_ci_clone_dest; updating"
                git -C "$_ci_clone_dest" fetch origin >/dev/null 2>&1 || true
                git -C "$_ci_clone_dest" reset --hard origin/HEAD >/dev/null 2>&1 \
                    || git -C "$_ci_clone_dest" reset --hard origin/main 2>/dev/null \
                    || git -C "$_ci_clone_dest" reset --hard origin/master 2>/dev/null \
                    || true
            else
                hw_log "cloning $_ci_arg..."
                rm -rf "$_ci_clone_dest"
                git clone "$_ci_arg" "$_ci_clone_dest" \
                    || hw_die "could not clone source repository: $_ci_arg" \
                              "Check the URL, your network connection, and that git is installed."
            fi

            _ci_source="$_ci_clone_dest"
            _ci_mode="managed"
            ;;
        *)
            # Local source: resolve to absolute path
            _ci_source=$(cd -P "$_ci_arg" 2>/dev/null && pwd) \
                || hw_die "source path does not exist: $_ci_arg" \
                          "Check the path and try again, or use a URL to clone a managed source."
            _ci_mode="local"
            ;;
    esac

    # Validate the source root has a .homeworld-module before committing
    if [ ! -f "$_ci_source/.homeworld-module" ]; then
        hw_die "source root has no .homeworld-module: $_ci_source" \
               "The source directory must contain a .homeworld-module manifest at its root."
    fi

    mkdir -p "$HW_STATE"
    hw_write_bytes "$HW_STATE/source" "$_ci_source"
    hw_write_bytes "$HW_STATE/source-mode" "$_ci_mode"

    hw_log "source configured: $_ci_source (mode: $_ci_mode)"
    hw_log ""

    cmd_install
}

# ---------------------------------------------------------------------------
# cmd_install
# ---------------------------------------------------------------------------

cmd_install() {
    _ci_dry_run=0
    _ci_reinstall=0
    _ci_yes=0
    _ci_source_override=""
    _ci_target_module=""
    _ci_gen=""
    _ci_lock=""

    # Parse flags — mixing flags and positional args is intentional
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run)      _ci_dry_run=1;          shift ;;
            --reinstall)    _ci_reinstall=1;         shift ;;
            --yes)          _ci_yes=1;               shift ;;
            --source)       _ci_source_override="$2"; shift 2 ;;
            --source=*)     _ci_source_override="${1#--source=}"; shift ;;
            -*)             hw_die "unknown option: $1" \
                            "Run 'homeworld --help' for usage." ;;
            *)              _ci_target_module="$1";  shift ;;
        esac
    done

    _hw_ensure_dirs

    # Determine source
    if [ -n "$_ci_source_override" ]; then
        _ci_source=$(cd -P "$_ci_source_override" 2>/dev/null && pwd) \
            || hw_die "source path does not exist: $_ci_source_override"
    else
        _ci_source=$(_hw_read_source)
    fi

    # Detect environment
    _ci_platform=$(hw_detect_platform)
    _ci_distro=$(hw_detect_distro)
    _ci_provider=$(hw_detect_provider "$_ci_platform")

    hw_log "Platform: $_ci_platform${_ci_distro:+, distro: $_ci_distro}${_ci_provider:+, provider: $_ci_provider}"

    # Discover and load all modules
    _ci_moddir=$(mktemp -d)
    # Ensure cleanup even on error
    _ci_moddir_set=1
    trap 'rm -rf "$_ci_moddir"' EXIT INT TERM

    hw_log "Discovering modules in $_ci_source..."
    _ci_all_names=$(hw_module_discover "$_ci_source" "$_ci_moddir") \
        || exit 1  # error already printed by hw_module_discover

    # Check root manifest HOMEWORLD_REQUIRES version constraint
    # The root module is the one whose path is the source root itself
    _ci_root_name=""
    for _ci_n in $_ci_all_names; do
        _ci_n_path=$(hw_module_get "$_ci_moddir" "$_ci_n" "path")
        if [ "$_ci_n_path" = "$_ci_source" ]; then
            _ci_root_name="$_ci_n"
            break
        fi
    done

    if [ -n "$_ci_root_name" ]; then
        _ci_requires=$(hw_module_get "$_ci_moddir" "$_ci_root_name" "requires")
        if [ -n "$_ci_requires" ]; then
            if ! hw_version_ge "$HW_VERSION" "$_ci_requires"; then
                hw_die "source requires homeworld >= $_ci_requires, but the installed version is $HW_VERSION" \
                       "Update homeworld by running its bootstrap installer again."
            fi
        fi
    fi

    # Filter modules by platform/distro/provider and show a grepable plan.
    # Nested module paths are indented in the MODULE column, while STATUS stays
    # fixed so `grep INSTALL` and `grep SKIP` remain useful.
    hw_log ""
    hw_log "Module plan:"
    _ci_applicable=""
    _ci_col_width=$(hw_module_display_width "$_ci_moddir" "$_ci_all_names" 20)
    _hw_print_module_header "$_ci_col_width" >&2

    for _ci_n in $_ci_all_names; do
        _ci_record=$(_hw_module_plan_record \
            "$_ci_moddir" "$_ci_n" "$_ci_platform" "$_ci_distro" \
            "${_ci_provider:-}" "$_ci_root_name")
        _ci_status=$(printf '%s' "$_ci_record" | cut -f1)
        _ci_detail=$(printf '%s' "$_ci_record" | cut -f2)
        _ci_is_applicable=$(printf '%s' "$_ci_record" | cut -f3)

        [ "$_ci_is_applicable" = "1" ] && _ci_applicable="$_ci_applicable $_ci_n"

        _ci_display=$(hw_module_display_name "$_ci_moddir" "$_ci_n" "$_ci_all_names")
        _hw_print_module_row "$_ci_status" "$_ci_display" "$_ci_detail" "$_ci_col_width" >&2
    done
    _ci_applicable="${_ci_applicable# }"
    hw_log ""

    # Handle explicit module request
    if [ -n "$_ci_target_module" ]; then
        # Verify the requested module is applicable
        _ci_target_ok=0
        for _ci_n in $_ci_applicable; do
            [ "$_ci_n" = "$_ci_target_module" ] && { _ci_target_ok=1; break; }
        done
        if [ "$_ci_target_ok" = "0" ]; then
            # Check if it exists at all
            _ci_exists=0
            for _ci_n in $_ci_all_names; do
                [ "$_ci_n" = "$_ci_target_module" ] && { _ci_exists=1; break; }
            done
            if [ "$_ci_exists" = "1" ]; then
                hw_die "module '$_ci_target_module' is not applicable on this platform (see SKIP reason above)"
            else
                hw_die "module '$_ci_target_module' not found in source" \
                       "Run 'homeworld list' to see all available modules."
            fi
        fi
        # Resolve transitive dependencies of the requested module, then merge in
        # the active generation's module list so a targeted install doesn't drop
        # config links managed by other modules.
        _ci_to_install=$(_hw_resolve_deps "$_ci_moddir" "$_ci_target_module" "$_ci_applicable")
        _ci_hw_cur=$(hw_current)
        if [ -L "$_ci_hw_cur" ]; then
            _ci_prev_gen=$(readlink "$_ci_hw_cur")
            _ci_prev_meta="$_ci_prev_gen/.homeworld/installed-modules"
            if [ -f "$_ci_prev_meta" ]; then
                while IFS= read -r _ci_prev_mod; do
                    [ -z "$_ci_prev_mod" ] && continue
                    # Skip modules no longer applicable on this system
                    _ci_still_ok=0
                    for _ci_n in $_ci_applicable; do
                        [ "$_ci_n" = "$_ci_prev_mod" ] && { _ci_still_ok=1; break; }
                    done
                    [ "$_ci_still_ok" = "0" ] && continue
                    # Skip if already in the plan
                    _ci_in_plan=0
                    for _ci_n in $_ci_to_install; do
                        [ "$_ci_n" = "$_ci_prev_mod" ] && { _ci_in_plan=1; break; }
                    done
                    [ "$_ci_in_plan" = "1" ] && continue
                    _ci_to_install="$_ci_to_install $_ci_prev_mod"
                done < "$_ci_prev_meta"
            fi
        fi
    else
        # Install all auto-install modules (plus root which is always included)
        _ci_to_install=""
        for _ci_n in $_ci_applicable; do
            _ci_auto=$(hw_module_get "$_ci_moddir" "$_ci_n" "auto_install")
            # Root module is always included; others respect auto_install flag
            if [ "$_ci_n" = "$_ci_root_name" ] || [ "${_ci_auto:-true}" != "false" ]; then
                _ci_to_install="$_ci_to_install $_ci_n"
            fi
        done
        _ci_to_install="${_ci_to_install# }"
    fi

    # Topological sort by dependency order
    _ci_sorted=$(hw_module_sort "$_ci_moddir" "$_ci_to_install")

    # Preflight: check for command name collisions
    hw_module_check_commands "$_ci_moddir" "$_ci_sorted"

    hw_log "Installation order: $( printf '%s' "$_ci_sorted" | tr ' ' '\n' | grep -v '^$' | tr '\n' ' ')"

    # Collect all packages into a temp file for batch install
    _ci_pkg_file=$(_hw_collect_all_packages "$_ci_moddir" "$_ci_sorted" "${_ci_provider:-}")

    if [ "$_ci_dry_run" = "1" ]; then
        hw_log ""
        hw_log "Dry run — no changes made."
        if [ -s "$_ci_pkg_file" ]; then
            hw_log ""
            hw_log "Packages that would be installed via ${_ci_provider:-unknown}:"
            grep -v '^[[:space:]]*$' "$_ci_pkg_file" | grep -v '^#' | sort -u | while read -r _ci_pkg; do
                hw_log "  $_ci_pkg"
            done
        fi
        rm -f "$_ci_pkg_file"
        return 0
    fi

    if [ "$_ci_reinstall" = 1 ] && [ "$_ci_yes" != 1 ]; then
        printf 'Rebuild Homeworld from declarations? [y/N] ' >&2
        if ! read -r _ci_confirm; then _ci_confirm=''; fi
        case "$_ci_confirm" in [yY]|[yY][eE][sS]) : ;; *) hw_log "Reinstall cancelled."; rm -f "$_ci_pkg_file"; return 0 ;; esac
    fi

    # One generation transaction at a time. Holding this lock through the build
    # makes pending repository realizations temporary garbage-collection roots.
    _ci_lock=$(hw_global_lock_dir)
    hw_lock_acquire "$_ci_lock" "installation"
    _ci_cleanup() {
        if [ -n "${_ci_gen:-}" ] && [ "$(cat "$_ci_gen/.homeworld/status" 2>/dev/null)" = pending ]; then
            hw_tree_make_removable "$_ci_gen"
            rm -rf "$_ci_gen"
        fi
        [ -z "${_ci_moddir:-}" ] || rm -rf "$_ci_moddir"
        [ -z "${_ci_lock:-}" ] || hw_lock_release "$_ci_lock"
    }
    trap '_ci_cleanup' EXIT HUP INT TERM
    hw_transaction_repair_locked

    # Install packages before module hooks. Package-manager changes remain
    # outside Homeworld's rollback boundary.
    if [ -s "$_ci_pkg_file" ] && [ -n "${_ci_provider:-}" ]; then
        hw_install_packages "$_ci_provider" "$_ci_pkg_file"
    fi
    rm -f "$_ci_pkg_file"

    _ci_gen=$(hw_gen_new)
    hw_log ""
    hw_log "Building generation $(basename "$_ci_gen")..."

    # Install each module in sorted order
    for _ci_n in $_ci_sorted; do
        hw_install_module "$_ci_moddir" "$_ci_n" "$_ci_gen" "$_ci_platform" "${_ci_distro:-}"
    done

    # Write metadata before activation so it's part of the generation
    hw_gen_write_meta "$_ci_gen" "$_ci_platform" "${_ci_distro:-}" "${_ci_provider:-}" "$_ci_sorted"

    hw_log ""
    hw_log "Activating generation $(basename "$_ci_gen")..."
    hw_gen_activate_locked "$_ci_gen"
    hw_gen_gc_locked

    # Write env.sh so shells can pick up the bin directory
    _hw_write_env_sh

    hw_log ""
    hw_log "Done. Generation $(basename "$_ci_gen") is now active."
    hw_log ""
    hw_log "Add homeworld commands to PATH by sourcing:"
    hw_log "  ${XDG_CONFIG_HOME:-$HOME/.config}/homeworld/env.sh"

    _ci_gen=""
    hw_lock_release "$_ci_lock"
    _ci_lock=""
    rm -rf "$_ci_moddir"
    _ci_moddir=""
    trap - EXIT HUP INT TERM
}

# ---------------------------------------------------------------------------
# cmd_list
# ---------------------------------------------------------------------------

cmd_list() {
    _cl_source=$(_hw_read_source)
    _cl_platform=$(hw_detect_platform)
    _cl_distro=$(hw_detect_distro)
    _cl_provider=$(hw_detect_provider "$_cl_platform")

    _cl_moddir=$(mktemp -d)
    trap 'rm -rf "$_cl_moddir"' EXIT INT TERM

    _cl_all=$(hw_module_discover "$_cl_source" "$_cl_moddir") \
        || exit 1  # error already printed by hw_module_discover

    _cl_root_name=""
    for _cl_n in $_cl_all; do
        _cl_n_path=$(hw_module_get "$_cl_moddir" "$_cl_n" "path")
        if [ "$_cl_n_path" = "$_cl_source" ]; then
            _cl_root_name="$_cl_n"
            break
        fi
    done

    _cl_col_width=$(hw_module_display_width "$_cl_moddir" "$_cl_all" 20)
    _hw_print_module_header "$_cl_col_width"

    for _cl_n in $_cl_all; do
        _cl_record=$(_hw_module_plan_record \
            "$_cl_moddir" "$_cl_n" "$_cl_platform" "$_cl_distro" \
            "${_cl_provider:-}" "$_cl_root_name")
        _cl_status=$(printf '%s' "$_cl_record" | cut -f1)
        _cl_detail=$(printf '%s' "$_cl_record" | cut -f2)
        _cl_display=$(hw_module_display_name "$_cl_moddir" "$_cl_n" "$_cl_all")
        _hw_print_module_row "$_cl_status" "$_cl_display" "$_cl_detail" "$_cl_col_width"
    done
}

# ---------------------------------------------------------------------------
# cmd_status
# ---------------------------------------------------------------------------

cmd_status() {
    _cs_current=$(hw_current)
    if [ ! -L "$_cs_current" ]; then
        hw_die "no active generation. Run 'homeworld install' first."
    fi

    _cs_gen=$(readlink "$_cs_current")
    _cs_id=$(basename "$_cs_gen")
    _cs_meta="$_cs_gen/.homeworld"

    printf 'Generation:  %s%s%s\n' "$_HW_C_BOLD" "$_cs_id" "$_HW_C_RST"

    if [ -f "$_cs_meta/created-at" ]; then
        printf 'Created:     %s\n' "$(cat "$_cs_meta/created-at")"
    fi
    if [ -f "$_cs_meta/platform" ]; then
        printf 'Platform:    %s\n' "$(cat "$_cs_meta/platform")"
    fi
    if [ -f "$_cs_meta/distro" ]; then
        _cs_distro=$(cat "$_cs_meta/distro")
        [ -n "$_cs_distro" ] && printf 'Distro:      %s\n' "$_cs_distro"
    fi
    if [ -f "$_cs_meta/package-provider" ]; then
        _cs_prov=$(cat "$_cs_meta/package-provider")
        [ -n "$_cs_prov" ] && printf 'Provider:    %s\n' "$_cs_prov"
    fi
    if [ -f "$_cs_meta/source-revision" ]; then
        printf 'Revision:    %s\n' "$(cat "$_cs_meta/source-revision")"
    fi
    if [ -f "$_cs_meta/installed-modules" ]; then
        printf 'Modules:     %s\n' "$(tr '\n' ' ' < "$_cs_meta/installed-modules")"
    fi

    if [ -L "$(hw_previous)" ]; then
        printf 'Previous:    %s\n' "$(basename "$(readlink "$(hw_previous)")")"
    fi
}

# ---------------------------------------------------------------------------
# cmd_update
# ---------------------------------------------------------------------------

cmd_update() {
    _cu_dependencies=0
    _cu_install=0
    _cu_check=0
    _cu_async=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --dependencies) _cu_dependencies=1 ;;
            --install) _cu_install=1 ;;
            --check) _cu_check=1 ;;
            --async) _cu_async=1 ;;
            --apply) _cu_install=1 ;;
            *) hw_die "unknown update option: $1" ;;
        esac
        shift
    done

    _cu_mode=local
    [ -f "$HW_STATE/source-mode" ] && _cu_mode=$(cat "$HW_STATE/source-mode")
    if [ "$_cu_mode" = managed ]; then
        _cu_source=$(_hw_read_source)
        hw_require git
        if [ "$_cu_async" = 1 ]; then
            git -C "$_cu_source" fetch origin >/dev/null 2>&1 || exit 0
            exit 0
        fi
        hw_log "Updating provisioning source..."
        git -C "$_cu_source" fetch origin || hw_die "could not fetch provisioning source"
        if [ "$_cu_check" = 1 ]; then
            _cu_behind=$(git -C "$_cu_source" rev-list HEAD..origin/HEAD --count 2>/dev/null || printf 0)
            [ "$_cu_behind" = 0 ] && hw_log "Already up to date." || hw_log "Update available: $_cu_behind commit(s)."
            return 0
        fi
        git -C "$_cu_source" merge --ff-only origin/HEAD >/dev/null 2>&1 \
            || git -C "$_cu_source" merge --ff-only origin/main >/dev/null 2>&1 \
            || git -C "$_cu_source" merge --ff-only origin/master >/dev/null 2>&1 \
            || hw_die "the provisioning source cannot be fast-forwarded"
    elif [ "$_cu_check" = 1 ]; then
        return 0
    else
        hw_log "Provisioning source is local; Homeworld will use its current contents."
    fi

    if [ "$_cu_dependencies" = 1 ]; then
        hw_log "Fetching repository dependencies..."
        hw_repo_update_current '' || hw_die "one or more repository dependencies could not be fetched"
    fi
    [ "$_cu_install" = 1 ] && cmd_install
}

# ---------------------------------------------------------------------------
# cmd_rollback
# ---------------------------------------------------------------------------

cmd_rollback() {
    hw_log "Rolling back to previous generation..."
    hw_gen_rollback
    hw_log "Rollback complete. Active generation: $(basename "$(readlink "$(hw_current)")")"
}

# ---------------------------------------------------------------------------
# cmd_generations
# ---------------------------------------------------------------------------

cmd_generations() {
    hw_gen_list
}

# ---------------------------------------------------------------------------
# cmd_gc
# ---------------------------------------------------------------------------

cmd_gc() {
    hw_log "Collecting unreferenced generations..."
    hw_gen_gc
    hw_log "Done."
}

# ---------------------------------------------------------------------------
# Resource commands
# ---------------------------------------------------------------------------

_hw_install_context() {
    [ -n "${HOMEWORLD_TARGET:-}" ] && [ -n "${HOMEWORLD_MODULE_NAME:-}" ] \
        || hw_die "$1 must be called from a module install.sh"
}

cmd_repo() {
    _cr_action=${1:-}; [ $# -gt 0 ] && shift
    case "$_cr_action" in
        add)
            _hw_install_context "homeworld repo add"
            [ $# -ge 2 ] || hw_die "usage: homeworld repo add <source> <namespace> [--ref <ref>]"
            _cr_source=$1; _cr_ns=$2; shift 2; _cr_ref=''
            while [ $# -gt 0 ]; do
                case "$1" in --ref) [ $# -ge 2 ] || hw_die "--ref requires a value"; _cr_ref=$2; shift 2 ;; *) hw_die "unknown repo add option: $1" ;; esac
            done
            hw_repo_add_to_gen "$_cr_source" "$_cr_ns" "$HOMEWORLD_TARGET" "$_cr_ref"
            ;;
        link)
            _hw_install_context "homeworld repo link"
            [ $# -eq 2 ] || hw_die "usage: homeworld repo link <namespace> <destination>"
            hw_repo_link "$1" "$2" "$HOMEWORLD_TARGET" "$HOMEWORLD_MODULE_NAME"
            ;;
        path)
            [ $# -eq 1 ] || hw_die "usage: homeworld repo path <namespace>"
            hw_repo_path "$1" || hw_die "repository is not available in this generation: $1"
            printf '\n'
            ;;
        update)
            [ $# -eq 1 ] || hw_die "usage: homeworld repo update <namespace|--all>"
            case "$1" in --all) hw_repo_update_current '' ;; *) hw_repo_update_current "$1" ;; esac \
                || hw_die "one or more repositories could not be fetched"
            ;;
        *) hw_die "unknown repo subcommand: ${_cr_action:-}" ;;
    esac
}

cmd_asset() {
    _ca_action=${1:-}; [ $# -gt 0 ] && shift
    case "$_ca_action" in
        add)
            _hw_install_context "homeworld asset add"
            [ $# -eq 2 ] || hw_die "usage: homeworld asset add <source> <name>"
            hw_asset_add "$1" "$2" "$HOMEWORLD_TARGET" "$HOMEWORLD_MODULE_NAME"
            ;;
        link)
            _hw_install_context "homeworld asset link"
            [ $# -eq 2 ] || hw_die "usage: homeworld asset link <name> <destination>"
            hw_asset_link "$1" "$2" "$HOMEWORLD_TARGET" "$HOMEWORLD_MODULE_NAME"
            ;;
        path)
            [ $# -eq 1 ] || hw_die "usage: homeworld asset path <module/name>"
            if [ -n "${HOMEWORLD_TARGET:-}" ]; then _ca_base=$HOMEWORLD_TARGET; else _ca_base=$(hw_current); fi
            printf '%s\n' "$(hw_safe_path "$_ca_base/assets" "$1")"
            ;;
        *) hw_die "unknown asset subcommand: ${_ca_action:-}" ;;
    esac
}

cmd_config() {
    _cc_action=${1:-}; [ $# -gt 0 ] && shift
    case "$_cc_action" in
        add)
            _hw_install_context "homeworld config add"
            [ $# -eq 2 ] || hw_die "usage: homeworld config add <source> <name>"
            hw_config_add "$1" "$2" "$HOMEWORLD_TARGET" "$HOMEWORLD_MODULE_NAME"
            ;;
        link)
            _hw_install_context "homeworld config link"
            [ $# -eq 2 ] || hw_die "usage: homeworld config link <name> <destination>"
            hw_config_link "$1" "$2" "$HOMEWORLD_MODULE_NAME" "$HOMEWORLD_TARGET"
            ;;
        path)
            [ $# -eq 1 ] || hw_die "usage: homeworld config path <module/name>"
            if [ -n "${HOMEWORLD_TARGET:-}" ]; then _cc_base=$HOMEWORLD_TARGET; else _cc_base=$(hw_current); fi
            printf '%s\n' "$(hw_safe_path "$_cc_base/config" "$1")"
            ;;
        *) hw_die "unknown config subcommand: ${_cc_action:-}" ;;
    esac
}

cmd_command() {
    _cco_action=${1:-}; [ $# -gt 0 ] && shift
    case "$_cco_action" in
        add)
            _hw_install_context "homeworld command add"
            [ $# -eq 2 ] || hw_die "usage: homeworld command add <source> <name>"
            case "$1" in
                /*) _cco_source=$1 ;;
                *) _cco_source=$(hw_safe_path "$HOMEWORLD_MODULE_ROOT" "$1") || hw_die "invalid command source path" ;;
            esac
            hw_command_add "$_cco_source" "$2" "$HOMEWORLD_TARGET" "$HOMEWORLD_MODULE_NAME"
            ;;
        path)
            [ $# -eq 1 ] || hw_die "usage: homeworld command path <name|self>"
            if [ "$1" = self ]; then
                [ -n "${HOMEWORLD_COMMAND_DIR:-}" ] || hw_die "command path self is only valid inside a Homeworld command"
                printf '%s\n' "$HOMEWORLD_COMMAND_DIR"
                return 0
            fi
            _cco_base=$(hw_current)
            [ -n "${HOMEWORLD_TARGET:-}" ] && _cco_base=$HOMEWORLD_TARGET
            _cco_found=''
            for _cco_path in "$_cco_base/commands"/*/"$1"; do [ -d "$_cco_path" ] && { [ -z "$_cco_found" ] || hw_die "command name is ambiguous: $1"; _cco_found=$_cco_path; }; done
            [ -n "$_cco_found" ] || hw_die "unknown Homeworld command: $1"
            printf '%s\n' "$_cco_found"
            ;;
        *) hw_die "unknown command subcommand: ${_cco_action:-}" ;;
    esac
}

cmd_state() {
    _cs_action=${1:-}; [ $# -gt 0 ] && shift
    case "$_cs_action" in
        bind)
            [ $# -eq 2 ] || hw_die "usage: homeworld state bind <name> <path>"
            hw_state_bind_update "$1" "$2"
            ;;
        link)
            _hw_install_context "homeworld state link"
            [ $# -eq 2 ] || hw_die "usage: homeworld state link <name-or-path> <destination>"
            hw_state_link "$1" "$2" "$HOMEWORLD_MODULE_NAME" "$HOMEWORLD_TARGET"
            ;;
        *) hw_die "unknown state subcommand: ${_cs_action:-}" ;;
    esac
}

cmd_generation() {
    _cg_action=${1:-}; [ $# -gt 0 ] && shift
    case "$_cg_action" in
        path)
            if [ "${1:-}" = self ]; then
                if [ -n "${HOMEWORLD_TARGET:-}" ]; then printf '%s\n' "$HOMEWORLD_TARGET"; else printf '%s\n' "$(hw_current)"; fi
            else
                [ $# -eq 0 ] || hw_die "usage: homeworld generation path [self]"
                [ -L "$(hw_current)" ] || hw_die "no active generation"
                printf '%s\n' "$(hw_current)"
            fi
            ;;
        list) hw_gen_list ;;
        rollback) hw_gen_rollback ;;
        gc) hw_gen_gc ;;
        *) hw_die "unknown generation subcommand: ${_cg_action:-}" ;;
    esac
}

cmd_module() {
    [ "${1:-}" = path ] || hw_die "usage: homeworld module path"
    [ -n "${HOMEWORLD_MODULE_ROOT:-}" ] || hw_die "module path is only valid during module installation"
    printf '%s\n' "$HOMEWORLD_MODULE_ROOT"
}

# ---------------------------------------------------------------------------
# cmd_doctor
# ---------------------------------------------------------------------------

cmd_doctor() {
    _cd_ok=1

    # Helpers local to doctor — color wraps only the status token, not the message.
    _dr_ok()   { printf '  %sOK%s    %s\n'   "$_HW_C_OK"   "$_HW_C_RST" "$*" >&2; }
    _dr_warn() { printf '  %sWARN%s  %s\n'   "$_HW_C_WARN" "$_HW_C_RST" "$*" >&2; }
    _dr_info() { printf '  %sINFO%s  %s\n'   "$_HW_C_BOLD" "$_HW_C_RST" "$*" >&2; }
    _dr_hint() { printf '        %s\n'        "$*" >&2; }

    # Check 1: homeworld on PATH
    if ! command -v homeworld >/dev/null 2>&1; then
        _dr_warn "homeworld is not on PATH"
        _dr_hint "Add ~/.local/bin to PATH or source ~/.config/homeworld/env.sh"
        _cd_ok=0
    else
        _dr_ok "homeworld is on PATH ($(command -v homeworld))"
    fi

    # Check 2: source configured
    if [ ! -f "$HW_STATE/source" ]; then
        _dr_warn "no source configured"
        _dr_hint "Run 'homeworld init <path>' to get started."
        _cd_ok=0
    else
        _cd_source=$(cat "$HW_STATE/source")
        if [ -d "$_cd_source" ]; then
            _dr_ok "source configured: $_cd_source"
        else
            _dr_warn "source path no longer exists: $_cd_source"
            _dr_hint "Run 'homeworld init <new-path>' to update the source."
            _cd_ok=0
        fi
    fi

    # Check 3: active generation
    if [ -L "$(hw_current)" ]; then
        _dr_ok "active generation: $(basename "$(readlink "$(hw_current)")")"
    else
        _dr_warn "no active generation"
        _dr_hint "Run 'homeworld install' to create one."
        _cd_ok=0
    fi

    # Check 4: git available (needed for managed sources)
    _cd_mode="local"
    [ -f "$HW_STATE/source-mode" ] && _cd_mode=$(cat "$HW_STATE/source-mode")
    if [ "$_cd_mode" = "managed" ]; then
        if command -v git >/dev/null 2>&1; then
            _dr_ok "git available (managed source mode)"
        else
            _dr_warn "git not found — updates will fail (source is managed)"
            _dr_hint "Install git and ensure it is on your PATH."
            _cd_ok=0
        fi
    else
        _dr_info "source mode: local (git not required)"
    fi

    # Check 5: env.sh in place
    _cd_env="${XDG_CONFIG_HOME:-$HOME/.config}/homeworld/env.sh"
    if [ -f "$_cd_env" ]; then
        _dr_ok "env.sh present at $_cd_env"
    else
        _dr_warn "env.sh not found at $_cd_env"
        _dr_hint "Run 'homeworld install' to regenerate it."
        _cd_ok=0
    fi

    hw_log ""
    if [ "$_cd_ok" = "1" ]; then
        printf '%sAll checks passed.%s\n' "$_HW_C_OK" "$_HW_C_RST" >&2
    else
        printf '%sSome checks failed.%s See warnings above.\n' "$_HW_C_WARN" "$_HW_C_RST" >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# main dispatch
# ---------------------------------------------------------------------------

main() {
    [ $# -gt 0 ] || { usage; exit 2; }
    _hw_ensure_dirs
    hw_transaction_repair

    cmd=$1; shift
    case "$cmd" in
        init) cmd_init "$@" ;;
        install) cmd_install "$@" ;;
        list) cmd_list "$@" ;;
        status) cmd_status "$@" ;;
        update) cmd_update "$@" ;;
        repo) cmd_repo "$@" ;;
        asset) cmd_asset "$@" ;;
        config) cmd_config "$@" ;;
        command) cmd_command "$@" ;;
        state) cmd_state "$@" ;;
        generation) cmd_generation "$@" ;;
        module) cmd_module "$@" ;;
        rollback) hw_die "renamed: homeworld generation rollback" ;;
        generations) hw_die "renamed: homeworld generation list" ;;
        gc) hw_die "renamed: homeworld generation gc" ;;
        path) hw_die "use the relevant resource path command" ;;
        doctor) cmd_doctor ;;
        --version|-V) printf 'homeworld %s\n' "$HW_VERSION" ;;
        --help|-h) usage ;;
        *) hw_die "unknown command: $cmd" \
                 "Run 'homeworld --help' for usage." ;;
    esac
}
main "$@"
