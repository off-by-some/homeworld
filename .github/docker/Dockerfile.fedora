FROM fedora:latest
RUN dnf install -y git ncurses dash busybox && dnf clean all
ENV LANG=C.UTF-8 LC_ALL=C.UTF-8
ENV PATH="/root/.local/bin:$PATH"
WORKDIR /homeworld
COPY . .
RUN sh install.sh
RUN sh tests/run.sh
RUN HOMEWORLD_TEST_SHELL=dash dash tests/run.sh
RUN HOMEWORLD_TEST_SHELL="busybox ash" busybox ash tests/run.sh
